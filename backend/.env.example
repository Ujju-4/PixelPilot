PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
MAX_UPLOAD_SIZE_BYTES=26214400

# Python interpreter for background removal, object removal, and magic expand.
# Default: python3 (Linux/macOS) or python (Windows — auto-detected).
# Override if your Python is at a different path, e.g.:
#   Windows:  PYTHON_EXECUTABLE=C:\Python312\python.exe
#   macOS:    PYTHON_EXECUTABLE=/usr/local/bin/python3
# PYTHON_EXECUTABLE=python3

# Tesseract OCR binary for the Extract Text feature.
# Default: tesseract (assumes it's on your PATH).
# Windows install: https://github.com/UB-Mannheim/tesseract/wiki
# Then set, e.g.: TESSERACT_EXECUTABLE=C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_EXECUTABLE=tesseract

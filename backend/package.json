{
  "name": "backend",
  "private": true,
  "version": "0.1.0",
  "description": "PixelPilot AI backend - Express + TypeScript API server",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "archiver": "^7.0.1",
    "dotenv": "^16.4.5",
    "exifr": "^7.1.3",
    "express": "^4.21.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "sharp": "^0.33.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/archiver": "^6.0.3",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.2"
  }
}
